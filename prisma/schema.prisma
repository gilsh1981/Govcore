generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ORGANIZATION ────────────────────────────────────────────────────────────

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users          User[]
  committees     Committee[]
  meetings       Meeting[]
  decisions      Decision[]
  tasks          Task[]
  auditLogs      AuditLog[]
  calendarEvents CalendarEvent[]
  documents      Document[]
  syncLogs       SyncLog[]
  roles          Role[]

  @@map("organizations")
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id            String       @id @default(uuid())
  orgId         String
  email         String
  phone         String?
  name          String?
  displayName   String?
  externalId    String?      // AD / LDAP sync identifier
  provider      AuthProvider @default(LOCAL)
  status        UserStatus   @default(ACTIVE)
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  // ── legacy flat role kept for JWT compat; fine-grained via UserRoleAssignment ──
  role          UserRole     @default(MEMBER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  org                  Organization         @relation(fields: [orgId], references: [id])
  accounts             Account[]
  sessions             Session[]
  roleAssignments      UserRoleAssignment[]
  committeeMemberships CommitteeMember[]
  chairedCommittees    Committee[]          @relation("CommitteeChair")
  createdMeetings      Meeting[]            @relation("MeetingCreator")
  createdDecisions     Decision[]           @relation("DecisionCreator")
  proposedDecisions    Decision[]           @relation("DecisionProposer")
  approvedDecisions    Decision[]           @relation("DecisionApprover")
  assignedTasks        Task[]               @relation("TaskAssignee")
  createdTasks         Task[]               @relation("TaskCreator")
  statusTransitions    StatusTransition[]
  permissionLogs       PermissionLog[]
  uploadedDocuments    Document[]

  @@unique([orgId, email])
  @@index([orgId])
  @@index([externalId])
  @@index([status])
  @@map("users")
}

enum AuthProvider {
  LOCAL
  AZURE_AD
  LDAP
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum UserRole {
  ADMIN
  SECRETARY
  MEMBER
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model Role {
  id          String    @id @default(uuid())
  orgId       String
  name        String
  scope       RoleScope
  // e.g. ["committee:read","committee:write","meeting:create"]
  permissions String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org         Organization         @relation(fields: [orgId], references: [id])
  assignments UserRoleAssignment[]

  @@unique([orgId, name, scope])
  @@index([orgId])
  @@map("roles")
}

enum RoleScope {
  ORGANIZATION
  COMMITTEE
  MEETING
}

model UserRoleAssignment {
  id         String    @id @default(uuid())
  userId     String
  roleId     String
  scopeType  RoleScope
  scopeId    String?   // null = applies to entire org scope
  assignedAt DateTime  @default(now())
  assignedBy String?   // userId of assigner

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId, scopeId])
  @@index([userId])
  @@index([roleId])
  @@map("user_role_assignments")
}

// ─── NEXTAUTH TABLES ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── RECURRENCE ──────────────────────────────────────────────────────────────

model RecurrenceRule {
  id          String              @id @default(uuid())
  frequency   RecurrenceFrequency
  interval    Int                 @default(1)
  daysOfWeek  Int[]               // 0=Sun, 1=Mon … 6=Sat
  dayOfMonth  Int?
  monthOfYear Int?
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime            @default(now())

  committees Committee[]
  meetings   Meeting[]

  @@map("recurrence_rules")
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

// ─── COMMITTEE ───────────────────────────────────────────────────────────────

model Committee {
  id               String    @id @default(uuid())
  orgId            String
  name             String
  description      String?
  chairUserId      String?
  recurrenceRuleId String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  org            Organization    @relation(fields: [orgId], references: [id])
  chair          User?           @relation("CommitteeChair", fields: [chairUserId], references: [id])
  recurrenceRule RecurrenceRule? @relation(fields: [recurrenceRuleId], references: [id])
  members        CommitteeMember[]
  meetings       Meeting[]

  @@index([orgId])
  @@index([isActive])
  @@map("committees")
}

model CommitteeMember {
  id          String        @id @default(uuid())
  committeeId String
  userId      String
  role        CommitteeRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@unique([committeeId, userId])
  @@map("committee_members")
}

enum CommitteeRole {
  CHAIR
  SECRETARY
  MEMBER
}

// ─── MEETING ─────────────────────────────────────────────────────────────────

model Meeting {
  id                   String        @id @default(uuid())
  orgId                String
  committeeId          String?       // null for standalone meetings
  title                String
  description          String?
  scheduledStart       DateTime
  scheduledEnd         DateTime?
  status               MeetingStatus @default(PLANNED)
  recurrenceRuleId     String?
  recurrenceInstanceId String?       // ISO date string "2025-03-10" for this instance
  minutes              Json?
  createdById          String?       // nullable for system-generated
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deletedAt            DateTime?

  org            Organization    @relation(fields: [orgId], references: [id])
  committee      Committee?      @relation(fields: [committeeId], references: [id])
  recurrenceRule RecurrenceRule? @relation(fields: [recurrenceRuleId], references: [id])
  createdBy      User?           @relation("MeetingCreator", fields: [createdById], references: [id])
  decisions      Decision[]
  documents      Document[]
  tasks          Task[]

  @@index([orgId])
  @@index([committeeId])
  @@index([scheduledStart])
  @@index([status])
  @@index([recurrenceRuleId, recurrenceInstanceId])
  @@map("meetings")
}

enum MeetingStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── DECISION ────────────────────────────────────────────────────────────────

model Decision {
  id             String         @id @default(uuid())
  organizationId String         @map("org_id")
  meetingId      String
  title          String
  description    String?        @db.Text
  status         DecisionStatus @default(PROPOSED)
  proposedById   String?
  approvedById   String?
  approvedAt     DateTime?
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  org        Organization @relation(fields: [organizationId], references: [id])
  meeting    Meeting      @relation(fields: [meetingId], references: [id])
  proposedBy User?        @relation("DecisionProposer", fields: [proposedById], references: [id])
  approvedBy User?        @relation("DecisionApprover", fields: [approvedById], references: [id])
  createdBy  User?        @relation("DecisionCreator", fields: [createdById], references: [id])
  tasks      Task[]

  @@index([organizationId])
  @@index([meetingId])
  @@index([status])
  @@index([proposedById])
  @@map("decisions")
}

enum DecisionStatus {
  PROPOSED
  APPROVED
  REJECTED
  ARCHIVED
}

// ─── TASK ─────────────────────────────────────────────────────────────────────

model Task {
  id             String       @id @default(uuid())
  organizationId String       @map("org_id")
  meetingId      String?
  decisionId     String?
  title          String
  description    String?      @db.Text
  assignedToId   String?
  dueDate        DateTime?
  priority       TaskPriority @default(MEDIUM)
  status         TaskStatus   @default(OPEN)
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  org        Organization @relation(fields: [organizationId], references: [id])
  meeting    Meeting?     @relation(fields: [meetingId], references: [id])
  decision   Decision?    @relation(fields: [decisionId], references: [id])
  assignedTo User?        @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdBy  User?        @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

// ─── STATUS TRANSITION ───────────────────────────────────────────────────────

model StatusTransition {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  fromStatus  String
  toStatus    String
  changedById String
  changedAt   DateTime @default(now())

  changedBy User @relation(fields: [changedById], references: [id])

  @@index([entityType, entityId])
  @@index([changedAt])
  @@map("status_transitions")
}

// ─── CALENDAR EVENT ──────────────────────────────────────────────────────────
// Governance-facing events (committees, one-off events, etc.)

model CalendarEvent {
  id               String    @id @default(uuid())
  orgId            String
  title            String
  description      String?
  startDate        DateTime
  endDate          DateTime?
  linkedEntityType String?   // "committee" | "meeting"
  linkedEntityId   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([startDate])
  @@index([linkedEntityType, linkedEntityId])
  @@map("calendar_events")
}

// ─── DOCUMENT ────────────────────────────────────────────────────────────────

model Document {
  id            String        @id @default(uuid())
  orgId         String
  meetingId     String?
  uploadedById  String?
  name          String
  mimeType      String
  storageKey    String        // cloud storage path/key
  sizeBytes     Int?
  visibility    DocVisibility @default(ORGANIZATION)
  isVoiceRecord Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  org        Organization @relation(fields: [orgId], references: [id])
  meeting    Meeting?     @relation(fields: [meetingId], references: [id])
  uploadedBy User?        @relation(fields: [uploadedById], references: [id])

  @@index([orgId])
  @@index([meetingId])
  @@index([uploadedById])
  @@map("documents")
}

enum DocVisibility {
  ORGANIZATION
  COMMITTEE
  MEETING
  PRIVATE
}

// ─── PERMISSION LOG ──────────────────────────────────────────────────────────

model PermissionLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  granted    Boolean
  reason     String?
  ip         String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("permission_logs")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────
// Domain event log (replaces previous Event model)

model AuditLog {
  id        String   @id @default(uuid())
  orgId     String
  type      String   // e.g. "committee.created"
  entityId  String
  payload   Json
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([type])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── SYNC LOG ────────────────────────────────────────────────────────────────

model SyncLog {
  id             String       @id @default(uuid())
  orgId          String
  provider       AuthProvider
  status         SyncStatus
  usersCreated   Int          @default(0)
  usersUpdated   Int          @default(0)
  usersDisabled  Int          @default(0)
  errors         Json?
  startedAt      DateTime     @default(now())
  completedAt    DateTime?

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([status])
  @@map("sync_logs")
}

enum SyncStatus {
  RUNNING
  COMPLETED
  FAILED
}
